{
  "name": "@crouton-kit/humanloop",
  "version": "0.3.12",
  "description": "Human-in-the-loop decision TUI — agents write questions, humans answer them",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hl": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "commands"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "link": "npm link",
    "postinstall": "node dist/scripts/install-renderer.js || true",
    "test": "tsx src/__tests__/mount-panel.test.ts"
  },
  "dependencies": {
    "@r-cli/sdk": "^1.3.0",
    "commander": "^13.0.0",
    "string-width": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
